{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Coly",
  "scopeName": "source.cly",
  "patterns": [
    { "include": "#comments" },
    { "include": "#define-statements" },
    { "include": "#code-block-marker" },
    { "include": "#embedded-code-blocks" },
    { "include": "#keywords" },
    { "include": "#variables" },
    { "include": "#special-vars" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.coly",
          "match": "^(\\|)?#.*$"
        }
      ]
    },
    "code-block-marker": {
      "patterns": [
        {
          "name": "punctuation.definition.coly",
          "match": "^\\|"
        }
      ]
    },
    "define-statements": {
      "patterns": [
        {
          "match": "\\b(define)\\b\\s+(var|privatevar|code|privatecode)\\s+\\b(named)\\b\\s+(\\S+)(?:\\s+\\b(with)\\b\\s+(.*))?$",
          "captures": {
            "1": { "name": "keyword.control.define.coly" },
            "2": { "name": "keyword.type.coly" },
            "3": { "name": "keyword.control.coly" },
            "4": { "name": "variable.other.coly" },
            "5": { "name": "keyword.control.coly" },
            "6": {
              "patterns": [
                { "include": "#keywords" },
                { "include": "#variables" }
              ]
            }
          }
        }
      ]
    },
    "embedded-code-blocks": {
      "patterns": [
        {
          "begin": "\\b(define)\\b\\s+(code|privatecode)\\s+\\b(named)\\b\\s+(\\S+)\\s+\\b(with)\\b\\s+(Python|JavaScript|TypeScript|Java|C\\+\\+|C#|Go|Rust|HTML|CSS)\\s*$",
          "beginCaptures": {
            "6": { "name": "constant.language.target-language.coly" }
          },
          "end": "^(?!\\|)",
          "patterns": [
            {
              "match": "^\\|",
              "name": "punctuation.definition.block.coly"
            },
            {
              "include": "source.$6"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.coly",
          "match": "\\b(print|printwithoutanewline|exit|NoReg|OnlyCompile|commitvaroperation|use|jump|if|ifn|named|with)\\b"
        },
        {
          "name": "constant.language.coly",
          "match": "\\b(false|true)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.coly",
          "match": "\\$(\\S+)(?=\\s|\\r|\\n|$)"
        }
      ]
    },
    "special-vars": {
      "patterns": [
        {
          "name": "support.variable.coly",
          "match": "\\b(Input|InputLine)\\b"
        }
      ]
    }
  }
}