{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Coly",
	"scopeName": "source.cly",
	"patterns": [
		{ "include": "#comments" },
		{ "include": "#define-statements" },
		{ "include": "#use-jump-statements" },
		{ "include": "#import-lib-statements" },
		{ "include": "#print-statements" },
		{ "include": "#python-code-blocks" },
		{ "include": "#code-block-marker" },
		{ "include": "#keywords" },
		{ "include": "#variables" },
		{ "include": "#special-vars" }
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"match": "^(#.*)$",
					"captures": {
						"1": { "name": "comment.line.number-sign.coly" }
					}
				},
				{
					"match": "^(\\|+)(#.*)$",
					"captures": {
						"1": { "name": "punctuation.definition.coly" },
						"2": { "name": "comment.line.number-sign.coly" }
					}
				}
			]
		},
		"pipe-line-override": {
			"patterns": [
				{
					"match": "^\\|.*$",
					"name": "text.plain.coly"
				}
			]
		},
		"code-block-marker": {
			"patterns": [
				{
					"name": "punctuation.definition.coly",
					"match": "^\\|"
				}
			]
		},
		"define-statements": {
			"patterns": [
				{
					"match": "\\b(define)\\b\\s+(var|privatevar|code|privatecode)\\s+\\b(named)\\b\\s+(\\S+)(?:\\s+\\b(with)\\b\\s+(.*))?$",
					"captures": {
						"1": { "name": "keyword.control.define.coly" },
						"2": { "name": "keyword.type.coly" },
						"3": { "name": "keyword.control.coly" },
						"4": { "name": "variable.other.coly" },
						"5": { "name": "keyword.control.coly" },
						"6": {
							"patterns": [
								{ "include": "#keywords" },
								{ "include": "#variables" }
							]
						}
					}
				}
			]
		},
		"use-jump-statements": {
			"patterns": [
				{
					"match": "\\b(use|jump)\\b\\s+(\\S+)",
					"captures": {
						"1": { "name": "keyword.control.coly" },
						"2": { "name": "variable.other.coly" }
					}
				},
				{
					"match": "\\b(use|jump)\\b\\s+to\\s+(\\S+)",
					"captures": {
						"1": { "name": "keyword.control.coly" },
						"2": { "name": "keyword.control.coly" },
						"3": { "name": "variable.other.coly" }
					}
				}
			]
		},
		"import-lib-statements": {
			"patterns": [
				{
					"match": "\\b(import)\\b\\s+(lib)\\s+(.*)$",
					"captures": {
						"1": { "name": "keyword.control.coly" },
						"2": { "name": "keyword.control.coly" },
						"3": { "name": "string.quoted.double.python" }
					}
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.coly",
					"match": "\\b(print|printwithoutanewline|exit|NoReg|OnlyCompile|commitvaroperation|if|ifn|named|with|to|import|lib)\\b"
				},
				{
					"name": "constant.language.coly",
					"match": "\\b(false|true)\\b"
				}
			]
		},
		"variables": {
			"patterns": [
				{
					"name": "variable.other.coly",
					"match": "\\$(\\S+)(?=\\s|\\r|\\n|$)"
				}
			]
		},
		"print-statements": {
			"patterns": [
				{
					"match": "\\b(print)\\b\\s+(.*)$",
					"captures": {
						"1": { "name": "keyword.control.coly" },
						"2": {
							"name": "string.quoted.double.python",
							"patterns": [
								{ "include": "#variables" }
							]
						}
					}
				}
			]
		},
		"special-vars": {
			"patterns": [
				{
					"name": "support.variable.coly",
					"match": "\\b(Input|InputLine)\\b"
				}
			]
		}
	}
}