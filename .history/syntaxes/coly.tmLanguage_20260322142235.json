{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Coly",
	"patterns": [
		{ "include": "#comments" },          // 1. 行首#注释（最高优先级）
		{ "include": "#code-block-marker" }, // 2. 代码块行首|符号
		{ "include": "#code-blocks" },       // 3. 多语言代码块（嵌入原生高亮）
		{ "include": "#keywords" },          // 4. Coly关键字
		{ "include": "#variables" }          // 5. $变量名
	],
	"repository": {
		// 1. 行首#注释规则
		"comments": {
			"patterns": [{
				"name": "comment.line.coly",
				"match": "^#.*$" // 匹配行首#开头的整行注释
			}]
		},

		// 2. 代码块行首|符号高亮
		"code-block-marker": {
			"patterns": [{
				"name": "punctuation.definition.coly",
				"match": "^\\|" // 匹配行首的|符号（无前置空格）
			}]
		},

		// 3. 核心：多语言代码块嵌入（C++/Python/Shell）
		"code-blocks": {
			"patterns": [
				// 3.1 C++代码块（// [cpp] 开始，// [end] 结束）
				{
					"begin": "^# \\[cpp\\]",
					"end": "^# \\[end\\]",
					"beginCaptures": {
						"0": { "name": "comment.line.coly.code-block-marker" }
					},
					"endCaptures": {
						"0": { "name": "comment.line.coly.code-block-marker" }
					},
					"patterns": [{
						"include": "source.cpp" // 复用VSCode内置C++高亮
					}],
					"applyEndPatternLast": true
				},
				// 3.2 Python代码块（// [python] 开始，// [end] 结束）
				{
					"begin": "^# \\[python\\]",
					"end": "^# \\[end\\]",
					"beginCaptures": {
						"0": { "name": "comment.line.coly.code-block-marker" }
					},
					"endCaptures": {
						"0": { "name": "comment.line.coly.code-block-marker" }
					},
					"patterns": [{
						"include": "source.python" // 复用VSCode内置Python高亮
					}],
					"applyEndPatternLast": true
				},
				// 3.3 Shell代码块（// [shell] 开始，// [end] 结束）
				{
					"begin": "^# \\[shell\\]",
					"end": "^# \\[end\\]",
					"beginCaptures": {
						"0": { "name": "comment.line.coly.code-block-marker" }
					},
					"endCaptures": {
						"0": { "name": "comment.line.coly.code-block-marker" }
					},
					"patterns": [{
						"include": "source.shell.bash" // 复用VSCode内置Shell高亮
					}],
					"applyEndPatternLast": true
				}
			]
		},

		// 4. Coly核心关键字
		"keywords": {
			"patterns": [{
				"name": "keyword.control.coly",
				"match": "\\b(print|printwithoutanewline|exit|with|define|var|code|named|privatevar|privatecode|Input|InputLine|NoReg|OnlyCompile|commitvaroperation|use|jump|if|ifn)\\b"
			}]
		},

		// 5. $变量名高亮（以空格/\r/\n/行尾结束）
		"variables": {
			"patterns": [{
				"name": "variable.other.coly",
				"match": "\\$(\\S+)(?=\\s|\\r|\\n|$)"
			}]
		}
	},
	"scopeName": "source.cly"
}