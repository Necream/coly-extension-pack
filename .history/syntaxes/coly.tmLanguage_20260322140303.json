{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Coly",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.coly",
				"match": "\\b(print|print)\\b"
			}]
		},
		"strings": {
			"name": "string.quoted.double.coly",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.coly",
					"match": "\\\\."
				}
			]
		}
	},
	"scopeName": "source.cly"
}