{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Coly",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#variables"
		},
		{
			"include": "#comments"
		},
		{
			"include"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.coly",
				"match": "\\b(print|printwithoutanewline|exit|with|define|var|code|named|privatevar|privatecode|Input|InputLine|NoReg|OnlyCompile|commitvaroperation|use|jump|if|ifn)\\b"
			},
			{
				"name": "constant.language.coly",
				"match": "\\b(false|true)\\b"
			}]
		},
		"variables": {
			"patterns": [{
				"name": "variable.other.coly",
				"match": "\\$(\\S+)(?=\\s|\\r|\\n|$)"
			}]
		},
		"comments": {
			"patterns": [{
				"name": "comment.line.number-sign.coly",
				"match": "#.*$"
			}]
		}
	},
	"scopeName": "source.cly"
}